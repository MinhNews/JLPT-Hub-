{
  "name": "jlpt-hub-backend",
  "version": "1.0.0",
  "description": "Commercial Backend API for JLPT Hub N3 learning application",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "seed": "ts-node src/services/seedData.ts",
    "seed-other": "ts-node src/services/seedOtherData.ts",
    "seed-exams": "ts-node src/services/seedExams.ts",
    "backfill-reading-translations": "ts-node src/scripts/backfillReadingTranslations.ts"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cloudinary": "^2.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^10.7.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "puppeteer": "^25.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.16",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.9.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
